{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "program": "bin/quicktype_dart.dart",
            "name": "Run Quicktype CLI",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Run build_runner (build)",
            "args": [
                "build"
            ],
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Run build_runner (watch)",
            "args": [
                "launch",
                "--delete-conflicting-outputs"
            ],
            "request": "attach",
            "type": "dart"
        },
        {
            "name": "quicktype_dart",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "quicktype_dart (attach)",
            "request": "attach",
            "type": "dart"
        },
        {
            "name": "quicktype_dart (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "quicktype_dart (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
    ]
}