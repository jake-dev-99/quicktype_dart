# Files excluded from the pub.dev tarball but kept in source control.
# Most ignored-by-git things are already excluded by .gitignore — this
# list covers in-repo things we don't want shipped.

# Node CLI bundle used for the Process transport's dev convenience. Large
# and redundant on machines that install `quicktype` globally via npm.
tool/

# Bundle regeneration workflow — devs only. The compiled bundle is
# already embedded in native/shim/bundle_data.c which ships.
native/bundle/shim.mjs
native/bundle/build_bundle.sh
native/bundle/package.json
native/bundle/package-lock.json
native/bundle/empty.cjs
native/bundle/quicktype_bundle.js

# Internal smoke tests (not part of the public surface). Glob so new
# smoke files added in `bin/` are automatically excluded — only
# `bin/quicktype_dart.dart` (the published CLI entry point) ships.
bin/smoke.dart
bin/*_smoke.dart

# Generator tool — dev-only, not needed at runtime or pub consumption.
tool/gen_options.py

# CI caches / editor state that might slip through.
.dart_tool/
.idea/
.vscode/
build/
